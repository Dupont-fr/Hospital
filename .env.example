# MongoDB Connection String
# Remplacez cette valeur par votre chaîne de connexion MongoDB
MONGODB_URI=votre_chaine_connexion_mongodb

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3000
NODE_ENV=development

# BREVO Email Configuration
# Obtenez votre clé API sur https://app.brevo.com/settings/keys
BREVO_API_KEY=votre_cle_api_brevo

# Email de l'expéditeur
BREVO_SENDER_EMAIL=votre_email@domaine.com
BREVO_SENDER_NAME=User Service

# Email de contact support (affiché dans les emails de notification)
SUPPORT_EMAIL=admin@hopital.com
